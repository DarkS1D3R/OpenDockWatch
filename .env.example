# Copy to .env and fill in real values. Never commit .env.

PORT=3000

# Set to "true" only if OpenDockWatch sits behind a reverse proxy (nginx, etc.) that you
# control and that terminates TLS / sets X-Forwarded-For itself. This makes Express trust
# the incoming X-Forwarded-For header for req.ip (needed for the session cookie's Secure
# flag and for the login rate limiter to see real client IPs) and marks the session cookie
# Secure. Leave unset/false if OpenDockWatch is reachable directly - otherwise a client can
# spoof X-Forwarded-For to get a fresh "IP" on every request, defeating the login rate
# limiter and forging the IP in auth.failure log lines.
TRUST_PROXY=

# Session cookie signing secret - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Login credentials for the OpenDockWatch UI
AUTH_USER=admin
# Generate with: npm run hash-password -- "your-password-here"
AUTH_PASS_HASH=

# Optional: a second, read-only login - can view everything (containers,
# stats, logs, topology, alerts) but cannot start/stop/restart containers.
# Leave both blank to disable. Generate the hash the same way as AUTH_PASS_HASH.
VIEWER_USER=
VIEWER_PASS_HASH=

# How long to keep collected data before it's pruned (days)
METRICS_RETENTION_DAYS=7
EVENTS_RETENTION_DAYS=30

# Optional: webhook for alerts (container crashed / crash-looping / unhealthy / host unreachable).
# The destination and payload format are picked from ALERT_WEBHOOK_URL's scheme:
#   discord://<webhook_id>/<webhook_token>
#   ntfy://<server>/<topic>       e.g. ntfy://ntfy.sh/mytopic, or a self-hosted host
#   gotify://<host>/<token>       (http)
#   gotifys://<host>/<token>      (https)
#   https://hooks.slack.com/...   (Slack incoming webhook - auto-detected)
#   any other http(s) URL         generic JSON POST of the alert object
# ALERT_WEBHOOK_FORMAT=slack forces the Slack {text} payload for a plain http(s)
# URL that isn't hooks.slack.com (e.g. a Slack-compatible Mattermost webhook).
# Can also be set (and changed without a restart) from the UI's Settings panel
# (admin only) - a value saved there always overrides these two.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_FORMAT=

# Optional: resource-threshold alerts (container/host CPU %, container/host mem %,
# Docker's own disk footprint). Each fires once a sample stays over threshold for
# ALERT_SUSTAIN_MINUTES (shared between the CPU and mem rules, since both are read
# from the same stats poll) - a single spike (image build, cron job, JVM startup)
# isn't enough. Leave a threshold blank or 0 to disable that rule; all four ship
# disabled. CPU % is raw `docker stats` CPU (per-core cumulative - 4 cores fully
# busy reads 400%). Docker disk usage is `docker system df`'s total Size across all
# rows - Docker's own footprint, not host filesystem free space, so it's a prune
# reminder rather than a disk-full alert. Skip a single container entirely with the
# `opendockwatch.alerts=off` container label. Can also be set (and changed without a
# restart) from the UI's Settings panel (admin only), same override rules as the
# webhook above.
ALERT_CPU_THRESHOLD=
ALERT_MEM_THRESHOLD=
ALERT_SUSTAIN_MINUTES=5
ALERT_DISK_THRESHOLD_GB=

# Optional: shared secret required to scrape GET /metrics (Prometheus). Leave blank to disable auth on it.
METRICS_TOKEN=
