# Copy to .env and fill in real values. Never commit .env.

PORT=3000

# Session cookie signing secret - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Login credentials for the OpenDockWatch UI
AUTH_USER=admin
# Generate with: npm run hash-password -- "your-password-here"
AUTH_PASS_HASH=

# Optional: a second, read-only login - can view everything (containers,
# stats, logs, topology, alerts) but cannot start/stop/restart containers.
# Leave both blank to disable. Generate the hash the same way as AUTH_PASS_HASH.
VIEWER_USER=
VIEWER_PASS_HASH=

# How long to keep collected data before it's pruned (days)
METRICS_RETENTION_DAYS=7
EVENTS_RETENTION_DAYS=30

# Optional: webhook for alerts (container crashed / crash-looping / unhealthy / host unreachable).
# The destination and payload format are picked from ALERT_WEBHOOK_URL's scheme:
#   discord://<webhook_id>/<webhook_token>
#   ntfy://<server>/<topic>       e.g. ntfy://ntfy.sh/mytopic, or a self-hosted host
#   gotify://<host>/<token>       (http)
#   gotifys://<host>/<token>      (https)
#   https://hooks.slack.com/...   (Slack incoming webhook - auto-detected)
#   any other http(s) URL         generic JSON POST of the alert object
# ALERT_WEBHOOK_FORMAT=slack forces the Slack {text} payload for a plain http(s)
# URL that isn't hooks.slack.com (e.g. a Slack-compatible Mattermost webhook).
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_FORMAT=

# Optional: shared secret required to scrape GET /metrics (Prometheus). Leave blank to disable auth on it.
METRICS_TOKEN=
